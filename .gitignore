# ==========================================
# YUNCAR - .gitignore
# Stack: React/Vite + Node/Express + Firebase
# ==========================================

# Dependencias
node_modules/
package-lock.json
yarn.lock

# Variables de entorno (CRÍTICO)
.env
.env.local
!.env.example

# Outputs de build
frontend/dist/
backend/dist/

# Logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/

# Sistema operativo
.DS_Store
Thumbs.db

# Firebase local (si usas emuladores)
.firebase/

# Temporales
*.tmp
*.temp